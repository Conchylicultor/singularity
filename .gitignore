# macOS
.DS_Store

# Dependencies
node_modules/

# Secrets
.env*
*.pem

# Test output
test-results/

# Build output
dist/
dist.staging.*/
dist.live.*/
dist.old.*/
# web-core publish: `dist` is a symlink → dist.live.<pid>; `dist.swap.*` is the
# transient swap symlink. Trailing-slash patterns don't match symlinks, so these
# are listed without a slash (the anchored path covers the live `dist` symlink).
plugins/framework/plugins/web-core/dist
dist.swap.*
# `VITE_ANALYZE=1` bundle-analysis treemap output (generated, never committed).
dist.stats.html
/gateway/gateway
**/.build.lock

# TypeScript
*.tsbuildinfo

# Composition build-gating: per-worktree filtered registries emitted only by
# `./singularity build --composition <name>` (never committed; siblings of the
# committed `<dir>.generated.ts`).
*.composition.generated.ts

# Caches
.cache/
.eslintcache

# Transient dirs created by ./singularity check (e.g. migrations-in-sync)
.check-*/

# v1 (Next.js) - extra lock file (uses bun.lock)
v1/package-lock.json

# Claude Code
skills-lock.json
.claude/worktrees/
.claude/scheduled_tasks.lock
.allow-main
.git-diff-main-reminded

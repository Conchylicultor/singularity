{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node", "@types/bun"]
  },
  "exclude": [
    "**/node_modules",
    "plugins/framework/plugins/web-core/vite.config.ts",
    "plugins/framework/plugins/server-core/scripts",
    "plugins/framework/plugins/tooling/plugins/checks/core/scripts",
    "plugins/**/*.test.ts",
    "plugins/**/*.test.tsx"
  ],
  "include": [
    "*.config.ts",
    "plugins/**/lint/*.ts",
    "plugins/**/scripts/*.ts",
    "plugins/**/provision/*.ts",
    "plugins/**/vite/*.ts",
    "plugins/**/*.config.ts",
    "plugins/infra/plugins/launcher/bin/*.ts"
  ]
}

  "views": {
    "public.attempts_v": {
      "columns": {
        "id": {
          "name": "id",
          "type": "text",
          "primaryKey": true,
          "notNull": true
        },
        "task_id": {
          "name": "task_id",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "worktree_path": {
          "name": "worktree_path",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "created_at": {
          "name": "created_at",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": true,
          "default": "now()"
        },
        "updated_at": {
          "name": "updated_at",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": true,
          "default": "now()"
        }
      },
      "definition": "with \"attempt_facts\" as (select \"id\", EXISTS (\n          SELECT 1 FROM \"conversations\" c WHERE c.attempt_id = \"attempts\".\"id\"\n        ) as \"has_conv\", EXISTS (\n          SELECT 1 FROM \"conversations\" c\n           WHERE c.attempt_id = \"attempts\".\"id\" AND c.status <> 'gone'\n        ) as \"has_live_conv\", EXISTS (\n          SELECT 1 FROM \"pushes\" p WHERE p.attempt_id = \"attempts\".\"id\"\n        ) as \"has_push\", (SELECT MIN(p.created_at) FROM \"pushes\" p WHERE p.attempt_id = \"attempts\".\"id\") as \"min_push_at\", (SELECT MAX(c.ended_at) FROM \"conversations\" c WHERE c.attempt_id = \"attempts\".\"id\") as \"max_ended_at\" from \"attempts\") select \"attempts\".\"id\", \"attempts\".\"task_id\", \"attempts\".\"worktree_path\", \"attempts\".\"created_at\", \"attempts\".\"updated_at\", \n        CASE\n          WHEN NOT \"has_conv\"                                       THEN 'pending'\n          WHEN \"has_live_conv\" AND NOT \"has_push\"               THEN 'in_progress'\n          WHEN \"has_live_conv\" AND \"has_push\"                   THEN 'pushed'\n          WHEN \"has_push\"                                            THEN 'completed'\n          ELSE                                                                  'abandoned'\n        END\n       as \"status\", ((NOT \"has_conv\") OR \"has_live_conv\") as \"active\", \n        CASE\n          WHEN \"has_push\" AND NOT \"has_live_conv\"               THEN \"min_push_at\"\n          WHEN \"has_conv\" AND NOT \"has_live_conv\"\n            AND NOT \"has_push\"                                       THEN \"max_ended_at\"\n          ELSE                                                                  NULL\n        END\n       as \"finished_at\" from \"attempts\" inner join \"attempt_facts\" on \"attempt_facts\".\"id\" = \"attempts\".\"id\"",
      "name": "attempts_v",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    },
    "public.tasks_v": {
      "columns": {
        "id": {
          "name": "id",
          "type": "text",
          "primaryKey": true,
          "notNull": true
        },
        "parent_id": {
          "name": "parent_id",

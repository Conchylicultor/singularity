        },
        "dropped_at": {
          "name": "dropped_at",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": false
        },
        "held_at": {
          "name": "held_at",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": false
        },
        "expanded": {
          "name": "expanded",
          "type": "boolean",
          "primaryKey": false,
          "notNull": true,
          "default": false
        },
        "rank": {
          "name": "rank",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "created_at": {
          "name": "created_at",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": true,
          "default": "now()"
        },
        "updated_at": {
          "name": "updated_at",
          "type": "timestamp with time zone",
          "primaryKey": false,
          "notNull": true,
          "default": "now()"
        }
      },
      "definition": "with \"task_facts\" as (select \"id\", EXISTS (\n          SELECT 1 FROM \"attempts\" a WHERE a.task_id = \"tasks\".\"id\"\n        ) as \"has_attempt\", EXISTS (\n          SELECT 1 FROM \"attempts_v\" a\n           WHERE a.task_id = \"tasks\".\"id\" AND a.status = 'completed'\n        ) as \"has_completed\", EXISTS (\n          SELECT 1 FROM \"attempts_v\" a\n           WHERE a.task_id = \"tasks\".\"id\" AND a.active\n        ) as \"has_active\", (\n          SELECT MIN(p.created_at)\n            FROM \"pushes\" p\n            JOIN \"attempts\" a ON a.id = p.attempt_id\n           WHERE a.task_id = \"tasks\".\"id\"\n        ) as \"min_completed_push_at\" from \"tasks\") select \"tasks\".\"id\", \"tasks\".\"parent_id\", \"tasks\".\"title\", \"tasks\".\"description\", \"tasks\".\"dropped_at\", \"tasks\".\"held_at\", \"tasks\".\"expanded\", \"tasks\".\"rank\", \"tasks\".\"created_at\", \"tasks\".\"updated_at\", \n        CASE\n          WHEN \"tasks\".\"dropped_at\" IS NOT NULL   THEN 'dropped'\n          WHEN \"tasks\".\"held_at\"    IS NOT NULL   THEN 'held'\n          WHEN \"has_completed\"             THEN 'done'\n          WHEN \"has_active\"                THEN 'in_progress'\n          WHEN \"has_attempt\"               THEN 'attempted'\n          ELSE                                        'new'\n        END\n       as \"status\", (\n        \"tasks\".\"dropped_at\" IS NULL\n        AND \"tasks\".\"held_at\" IS NULL\n        AND NOT \"has_completed\"\n        AND \"has_active\"\n      ) as \"active\", \n        CASE\n          WHEN \"tasks\".\"dropped_at\" IS NOT NULL   THEN \"tasks\".\"dropped_at\"\n          WHEN \"has_completed\"             THEN \"min_completed_push_at\"\n          ELSE                                        NULL\n        END\n       as \"finished_at\" from \"tasks\" inner join \"task_facts\" on \"task_facts\".\"id\" = \"tasks\".\"id\"",
      "name": "tasks_v",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    },

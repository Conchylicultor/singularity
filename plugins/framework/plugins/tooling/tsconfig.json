{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "types": ["@types/bun"],
    "paths": {
      "@plugins/*": ["../../../*"]
    }
  },
  "exclude": [
    "../../../framework/plugins/web-sdk/**",
    "**/node_modules"
  ],
  "include": [
    "core",
    "plugins/*/core",
    "plugins/*/bin"
  ]
}

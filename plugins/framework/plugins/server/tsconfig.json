{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "types": ["@types/bun"],
    "paths": {
      "@plugins/*": ["../../../*"],
      "@server/*": ["./core/*"]
    }
  },
  "exclude": [
    "../../../framework/plugins/web-sdk/**"
  ],
  "include": [
    "bin",
    "core",
    "../../../*/server",
    "../../../*/core",
    "../../../*/shared",
    "../../../*/check",
    "../../../*/plugins/*/server",
    "../../../*/plugins/*/core",
    "../../../*/plugins/*/shared",
    "../../../*/plugins/*/check",
    "../../../*/plugins/*/plugins/*/server",
    "../../../*/plugins/*/plugins/*/core",
    "../../../*/plugins/*/plugins/*/shared",
    "../../../*/plugins/*/plugins/*/plugins/*/server",
    "../../../*/plugins/*/plugins/*/plugins/*/core",
    "../../../*/plugins/*/plugins/*/plugins/*/shared",
    "../../../*/plugins/*/plugins/*/plugins/*/plugins/*/server",
    "../../../*/plugins/*/plugins/*/plugins/*/plugins/*/core",
    "../../../*/plugins/*/plugins/*/plugins/*/plugins/*/shared"
  ]
}

{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "paths": {
      "@/*": ["./web/*"],
      "@plugins/*": ["../../../*"]
    }
  },
  "exclude": [
    "../../../plugin-meta/plugins/plugin-tree/**",
    "../../../plugin-meta/plugins/barrel-import/**",
    "../tooling/**",
    "**/node_modules"
  ],
  "include": [
    "web",
    "../../../../**/plugins/*/web",
    "../../../../**/plugins/*/core",
    "../../../../**/plugins/*/shared"
  ]
}

{
  "views": [
    {
      "name": "Tree",
      "view": {
        "type": "tree",
        "filter": {
          "kind": "group",
          "id": "default",
          "conjunction": "and",
          "children": [
            {
              "kind": "rule",
              "id": "hide-completed",
              "fieldId": "status",
              "operatorId": "is-none-of",
              "value": ["done", "dropped"]
            }
          ]
        }
      }
    }
  ]
}

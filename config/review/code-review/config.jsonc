// @hash a03269e2c498
{
  // Path prefixes that require no special attention during review.
  "safePaths": [
    { "path": "plugins/" },
    { "path": "docs/" },
    { "path": "e2e/" },
    { "path": "research/" },
    { "path": "sidequests/" },
    { "path": "bun.lock" }
  ],
  // Path prefixes that deserve extra care.
  "carefulPaths": [
    { "path": "web/src/plugins.ts" },
    { "path": "server/src/db/migrations/" },
    { "path": "web/src/plugins.generated.ts" },
    { "path": "server/src/plugins.generated.ts" },
    { "path": "plugins/framework/" }
  ],
  // Named groups of file patterns for organizing code review.
  "sections": [
    {
      "name": "Doc",
      "patterns": [
        { "pattern": "docs/routes.md" },
        { "pattern": "**/CLAUDE.md" },
        { "pattern": "docs/plugins-compact.md" },
        { "pattern": "docs/plugins-details.md" },
        { "pattern": "research/" }
      ]
    },
    {
      "name": "Auto-generated",
      "patterns": [
        { "pattern": "bun.lock" },
        { "pattern": "server/src/db/migrations/" },
        { "pattern": "web/src/plugins.generated.ts" }
      ]
    },
    {
      "name": "Danger",
      "patterns": [
        { "pattern": "plugins/framework/" }
      ]
    }
  ]
}

{
  "views": [
    {
      "id": "queue",
      "name": "Queue",
      "source": "queue",
      "view": { "type": "list", "groupBy": "section" }
    },
    {
      "id": "history",
      "name": "History",
      "source": "history",
      "view": { "type": "list", "sort": [{ "fieldId": "createdAt", "direction": "desc" }] }
    }
  ],
  "filterPresets": [
    {
      "label": "Hide system",
      "group": {
        "kind": "group",
        "id": "hide-system",
        "conjunction": "and",
        "children": [
          {
            "kind": "rule",
            "id": "no-system",
            "fieldId": "kind",
            "operatorId": "is-none-of",
            "value": ["system"]
          }
        ]
      }
    }
  ]
}

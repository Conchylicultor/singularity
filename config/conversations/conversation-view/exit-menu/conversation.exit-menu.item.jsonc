{
  // Hide: { "item": "<key>", "hidden": true }
  // Spacer (gap): { "type": "spacer", "id": "<unique-id>" }
  // Group: { "type": "header", "label": "<title>", "collapsed": false, "items": [ "<key>", … ] }
  // Deliberate menu order (was the hardcoded `order` prop): hold → exit → drop → drop-dependents.
  "items": [
    "conversations.conversation-view.hold-and-exit:hold-and-exit",
    "conversations.conversation-view.exit:exit",
    "conversations.conversation-view.drop-and-exit:drop-and-exit",
    "conversations.conversation-view.drop-dependents:drop-dependents"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    "types": ["@types/bun"],
    "paths": {
      "@plugins/*": ["../plugins/*"],
      "@central/*": ["./bin/*"]
    }
  },
  "exclude": [
    "../plugins/framework/plugins/web-sdk/**",
    "**/node_modules"
  ],
  "include": [
    "bin",
    "../**/plugins/*/central",
    "../**/plugins/*/core",
    "../**/plugins/*/shared"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@types/bun"],
    "paths": {
      "@plugins/*": ["../plugins/*"],
      "@central/*": ["./src/*"],
      "@core/*": ["../plugins/framework/plugins/web-sdk/core/*"]
    }
  },
  "exclude": [
    "../plugins/framework/plugins/web-sdk/**"
  ],
  "include": [
    "src",
    "../plugins/*/central",
    "../plugins/*/core",
    "../plugins/*/shared",
    "../plugins/*/plugins/*/central",
    "../plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/shared",
    "../plugins/*/plugins/*/plugins/*/central",
    "../plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/shared",
    "../plugins/*/plugins/*/plugins/*/plugins/*/central",
    "../plugins/*/plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/plugins/*/shared"
  ]
}

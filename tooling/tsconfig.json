{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@types/bun"],
    "paths": {
      "@plugins/*": ["../plugins/*"],
      "@tooling/*": ["./src/*"],
      "@core/*": ["../plugins/framework/plugins/web-sdk/core/*"]
    }
  },
  "include": ["src", "../plugins/packages/plugins/*/shared"]
}

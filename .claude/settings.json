{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": ["EnterWorktree", "ExitWorktree"]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun cli/src/guard.ts"
          }
        ]
      }
    ]
  }
}

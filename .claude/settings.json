{
  "showThinkingSummaries": true,
  "env": {},
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": ["EnterWorktree", "ExitWorktree"]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"continue\": false, \"stopReason\": \"Context window full — session stopped (auto-compaction disabled)\"}'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|Read|NotebookEdit|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun tooling/src/guard.ts"
          }
        ]
      }
    ]
  }
}

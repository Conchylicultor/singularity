{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": ["EnterWorktree", "ExitWorktree"]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-main-edits.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-find.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-migrations.sh"
          }
        ]
      }
    ]
  }
}

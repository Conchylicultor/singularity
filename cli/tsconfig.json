{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@types/bun"],
    "paths": {
      "@packages/*": ["../packages/*"]
    }
  },
  "include": ["src", "../packages/*"]
}

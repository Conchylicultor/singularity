{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "@types/bun"],
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "paths": {
      "@plugins/*": ["./plugins/*"]
    }
  },
  "exclude": ["**/node_modules"],
  "include": [
    "plugins/**/*.test.ts",
    "plugins/**/*.test.tsx",
    "plugins/**/__tests__/**/*"
  ]
}

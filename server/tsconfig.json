{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@types/bun"],
    "paths": {
      "@plugins/*": ["../plugins/*"],
      "@server/*": ["./src/*"],
      "@core/*": ["../plugin-core/*"]
    }
  },
  "include": [
    "src",
    "../plugins/*/server",
    "../plugins/*/core",
    "../plugins/*/internal",
    "../plugins/*/check",
    "../plugins/*/plugins/*/server",
    "../plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/internal",
    "../plugins/*/plugins/*/check",
    "../plugins/*/plugins/*/plugins/*/server",
    "../plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/internal",
    "../plugins/*/plugins/*/plugins/*/plugins/*/server",
    "../plugins/*/plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/plugins/*/internal",
    "../plugins/*/plugins/*/plugins/*/plugins/*/plugins/*/server",
    "../plugins/*/plugins/*/plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/plugins/*/plugins/*/internal"
  ]
}

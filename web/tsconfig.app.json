{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"],
      "@core": ["../plugin-core"],
      "@core/*": ["../plugin-core/*"],
      "@plugins/*": ["../plugins/*"],
      "@server/*": ["../server/src/*"]
    }
  },
  "exclude": [
    "../plugins/plugin-meta/plugins/plugin-tree/**",
    "../plugins/plugin-meta/plugins/barrel-import/**"
  ],
  "include": [
    "src",
    "../plugin-core",
    "../plugins/*/web",
    "../plugins/*/core",
    "../plugins/*/shared",
    "../plugins/*/lint",
    "../plugins/*/plugins/*/web",
    "../plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/shared",
    "../plugins/*/plugins/*/lint",
    "../plugins/*/plugins/*/plugins/*/web",
    "../plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/shared",
    "../plugins/*/plugins/*/plugins/*/plugins/*/web",
    "../plugins/*/plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/plugins/*/shared",
    "../plugins/*/plugins/*/plugins/*/plugins/*/plugins/*/web",
    "../plugins/*/plugins/*/plugins/*/plugins/*/plugins/*/core",
    "../plugins/*/plugins/*/plugins/*/plugins/*/plugins/*/shared"
  ]
}
